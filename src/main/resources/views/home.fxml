<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="510.0" prefWidth="530.0" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/25" fx:controller="controllers.HomeController">

    <children>

        <Label layoutX="174.0" layoutY="47.0" text="PROGRAMA CALCULO DE GRAFOS" />

        <TextField fx:id="graphNameField" layoutX="238.0" layoutY="128.0" prefWidth="200" promptText="Ingresar Nombre De Grafo" />

        <Button layoutX="68.0" layoutY="128.0" onAction="#handleCreateGraph" prefHeight="25.0" prefWidth="133.0" text="GENERAR GRAFO" />

        <ListView fx:id="graphListView" layoutX="238.0" layoutY="277.0" prefHeight="120" prefWidth="200" />

        <Button layoutX="68.0" layoutY="277.0" onAction="#handleSelectGraph" text="SELECCIONAR GRAFO" />

    </children>

</AnchorPane>
